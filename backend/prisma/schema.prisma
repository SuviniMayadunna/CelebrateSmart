// Prisma schema for PostgreSQL database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  phone         String
  role          Role           @default(CUSTOMER)
  events        Event[]
  cartItems     CartItem[]
  orders        Order[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([email])
  @@map("users")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  content   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model NotificationBroadcast {
  id             String   @id @default(uuid())
  title          String
  content        String
  recipientType  String
  recipientCount Int
  sentBy         String
  createdAt      DateTime @default(now())

  @@map("notification_broadcasts")
}

model Event {
  id           String      @id @default(uuid())
  userId       String
  templateId   String?
  packageId    String?
  name         String
  type         String
  date         DateTime
  time         String
  venue        String
  venueBooked  String?
  guestCount   Int?
  notes        String?
  colorTheme   String?
  status       EventStatus @default(DRAFT)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  template     Template?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  package      Package?    @relation(fields: [packageId], references: [id], onDelete: SetNull)
  tasks        EventTask[]
  cartItems    CartItem[]
  orders       Order[]
  plan         EventPlan?
  visionBoard  VisionBoard?
  budget       EventBudget?
  guestList    GuestList?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([templateId])
  @@index([packageId])
  @@map("events")
}

model EventTask {
  id          String       @id @default(uuid())
  eventId     String
  title       String
  category    TaskCategory
  isCompleted Boolean      @default(false)
  completedAt DateTime?
  notes       String?
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([eventId])
  @@map("event_tasks")
}

model Template {
  id          String         @id @default(uuid())
  slug        String         @unique
  name        String
  emoji       String?
  description String
  isActive    Boolean        @default(true)
  steps       TemplateStep[]
  events      Event[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("templates")
}

model TemplateStep {
  id         String       @id @default(uuid())
  templateId String
  title      String
  category   TaskCategory
  sortOrder  Int
  template   Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([templateId])
  @@unique([templateId, sortOrder])
  @@map("template_steps")
}

model Product {
  id           String          @id @default(uuid())
  sku          String          @unique
  name         String
  description  String?
  category     ProductCategory
  imageUrl     String?
  venueAddress String?
  price        Decimal         @db.Decimal(10, 2)
  isActive     Boolean         @default(true)
  cartItems    CartItem[]
  orderItems   OrderItem[]
  packageItems PackageItem[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([category])
  @@map("products")
}

model Package {
  id          String         @id @default(uuid())
  name        String
  eventType   String
  tier        PackageTier
  description String
  highlights  String[]
  isActive    Boolean        @default(true)
  items       PackageItem[]
  photos      PackagePhoto[]
  events      Event[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([eventType, tier])
  @@index([eventType])
  @@map("packages")
}

model PackagePhoto {
  id        String   @id @default(uuid())
  packageId String
  url       String
  publicId  String
  caption   String?
  sortOrder Int      @default(0)
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([packageId])
  @@map("package_photos")
}

model PackageItem {
  id        String   @id @default(uuid())
  packageId String
  productId String
  quantity  Int      @default(1)
  isCore    Boolean  @default(true)
  sortOrder Int      @default(0)
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageId])
  @@map("package_items")
}

model EventPlan {
  id        String          @id @default(uuid())
  eventId   String          @unique
  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  steps     EventPlanStep[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("event_plans")
}

model EventPlanStep {
  id          String    @id @default(uuid())
  planId      String
  weeksBefore Int
  timeOfDay   String?
  title       String
  description String?
  category    String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int
  plan        EventPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([planId])
  @@map("event_plan_steps")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  eventId   String?
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([eventId])
  @@unique([userId, productId, eventId])
  @@map("cart_items")
}

model Order {
  id              String       @id @default(uuid())
  userId          String
  eventId         String?
  orderNumber     String       @unique @default(cuid())
  status          OrderStatus  @default(PENDING_PAYMENT)
  totalAmount     Decimal      @db.Decimal(10, 2)
  currency        String       @default("usd")
  paymentStatus   PaymentState @default(PENDING)
  deliveryAddress    String?
  originalGuestCount Int?
  cancellationFee    Decimal?     @db.Decimal(10, 2)
  refundAmount       Decimal?     @db.Decimal(10, 2)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  event         Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  payment       Payment?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([eventId])
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  productId    String
  productName  String
  unitPrice    Decimal  @db.Decimal(10, 2)
  quantity     Int
  categoryName String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id             String       @id @default(uuid())
  orderId         String       @unique
  provider        String       @default("STRIPE")
  paymentIntentId String?      @unique
  clientSecret    String?
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("usd")
  status          PaymentState @default(PENDING)
  failureReason   String?
  paidAt          DateTime?
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("payments")
}

enum PackageTier {
  BRONZE
  SILVER
  GOLD
}

enum Role {
  CUSTOMER
  ADMIN
}

enum EventStatus {
  DRAFT
  PLANNING
  READY
  COMPLETED
  CANCELED
}

enum TaskCategory {
  CAKE
  DECORATIONS
  FOOD
  ENTERTAINMENT
  PHOTOGRAPHY
  GIFTS
  VENUE
  FLOWERS
  CELEBRATION_DINNER
  GAMES
  PARTY_FAVORS
  GAMES_AND_ACTIVITIES
}

enum ProductCategory {
  CAKES
  DECORATIONS
  FOOD
  GIFTS
  PHOTOGRAPHY
  ENTERTAINMENT
  VENUE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELED
}

enum PaymentState {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

// ─── EVENT WORKSPACE ─────────────────────────────────────────────────────────

model VisionBoard {
  id            String      @id @default(uuid())
  eventId       String      @unique
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  colorPalette  String[]
  styleKeywords String[]
  pins          VisionPin[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("vision_boards")
}

model VisionPin {
  id        String      @id @default(uuid())
  boardId   String
  board     VisionBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  section   PinSection
  imageUrl  String?
  caption   String?
  notes     String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([boardId])
  @@map("vision_pins")
}

enum PinSection {
  MOOD
  DECOR
  OUTFIT
  LAYOUT
  FOOD
  ENTERTAINMENT
}

model EventBudget {
  id          String          @id @default(uuid())
  eventId     String          @unique
  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  totalBudget Decimal         @default(0) @db.Decimal(10, 2)
  currency    String          @default("usd")
  expenses    BudgetExpense[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("event_budgets")
}

model BudgetExpense {
  id          String          @id @default(uuid())
  budgetId    String
  budget      EventBudget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  description String
  amount      Decimal         @db.Decimal(10, 2)
  paidAt      DateTime?
  receiptNote String?
  source      ExpenseSource   @default(MANUAL)
  orderId     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([budgetId])
  @@map("budget_expenses")
}

enum ExpenseCategory {
  VENUE
  CATERING
  PHOTOGRAPHY
  DECORATIONS
  ENTERTAINMENT
  ATTIRE
  INVITATIONS
  MISCELLANEOUS
}

enum ExpenseSource {
  MANUAL
  ORDER
}

model GuestList {
  id        String   @id @default(uuid())
  eventId   String   @unique
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guests    Guest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guest_lists")
}

model Guest {
  id                  String        @id @default(uuid())
  guestListId         String
  guestList           GuestList     @relation(fields: [guestListId], references: [id], onDelete: Cascade)
  name                String
  email               String?
  phone               String?
  status              GuestStatus   @default(PENDING)
  category            GuestCategory @default(FRIENDS)
  tableNumber         String?
  mealPreference      String?
  dietaryRestrictions String?
  plusOnes            Int           @default(0)
  notes               String?
  rsvpToken           String?       @unique
  invitationSentAt    DateTime?
  rsvpAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([guestListId])
  @@map("guests")
}

enum GuestStatus {
  INVITED
  CONFIRMED
  DECLINED
  PENDING
  ATTENDED
  NO_SHOW
}

enum GuestCategory {
  FAMILY
  RELATIVES
  FRIENDS
  COLLEAGUES
  VIP
  KIDS
}
