# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Database Configuration
# Local development:
DATABASE_URL=postgresql://celebratesmart:celebratesmart123@localhost:5432/celebratesmart_db
# Docker (used automatically by docker-compose, host = service name "postgres"):
# DATABASE_URL=postgresql://celebratesmart:celebratesmart123@postgres:5432/celebratesmart_db

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=celebratesmart
POSTGRES_PASSWORD=celebratesmart123
POSTGRES_DB=celebratesmart_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CLIENT_URL=http://localhost:5173

# Stripe (add when implementing payments - Day 3)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
